OutrosTab:Toggle({Title = "Ativar Passe Livre", Desc = "Noclip automático na área (Raio: 3 studs)", Default = false, Callback = function(v)
    PasseLivre_Ativado = v
    if v then
        if PasseLivre_Conexao then PasseLivre_Conexao:Disconnect() end
        PasseLivre_Conexao = RunService.Heartbeat:Connect(function()
            if not PasseLivre_Ativado then return end
            local char = localPlayer.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            local root = char.HumanoidRootPart
            local posHorizontal = Vector3.new(root.Position.X, 0, root.Position.Z)
            local centroHorizontal = Vector3.new(PasseLivre_Centro.X, 0, PasseLivre_Centro.Z)
            local distancia = (posHorizontal - centroHorizontal).Magnitude
            if distancia <= PasseLivre_Raio then
                if not PasseLivre_NoClipAtivo then
                    PasseLivre_NoClipAtivo = true
                    for _, part in pairs(char:GetDescendants()) do
                        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then part.CanCollide = false end
                    end
                    root.CanCollide = false
                    WindUI:Notify({Title = "Passe Livre", Content = "✅ Noclip ATIVADO na área!"})
                end
            else
                if PasseLivre_NoClipAtivo then
                    PasseLivre_NoClipAtivo = false
                    for _, part in pairs(char:GetDescendants()) do
                        if part:IsA("BasePart") then part.CanCollide = true end
                    end
                    WindUI:Notify({Title = "Passe Livre", Content = "❌ Noclip DESATIVADO (saiu da área)"})
                end
            end
        end)
        WindUI:Notify({Title = "Passe Livre", Content = "🟢 Sistema ativo! Vá até a área."})
    else
        if PasseLivre_Conexao then PasseLivre_Conexao:Disconnect(); PasseLivre_Conexao = nil end
        if PasseLivre_NoClipAtivo then
            PasseLivre_NoClipAtivo = false
            local char = localPlayer.Character
            if char then
                for _, part in pairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then part.CanCollide = true end
                end
            end
        end
        WindUI:Notify({Title = "Passe Livre", Content = "🔴 Sistema desativado!"})
    end
end})

