-- ==========================================
-- LOOP PRINCIPAL
-- ==========================================
RunService.RenderStepped:Connect(function()
    local camera = Workspace.CurrentCamera
    local viewportTamanho = camera.ViewportSize
    if Aimbot_UsarFOV and FOVCircle then
        FOVCircle.Position = Vector2.new(viewportTamanho.X / 2, (viewportTamanho.Y / 2) + Aimbot_OffsetTelaY)
        FOVCircle.Radius = Aimbot_RaioFOV; FOVCircle.Thickness = Aimbot_EspessuraFOV
    end
    if Aimbot_Ativado then
        local alvo = ObterJogadorMaisProximoDaMira()
        if alvo and alvo.Character then
            local parteRastrear = nil
            if Aimbot_ParteAlvo == "Head" then
                parteRastrear = alvo.Character:FindFirstChild("Head")
            elseif Aimbot_ParteAlvo == "Torso" then
                parteRastrear = alvo.Character:FindFirstChild("UpperTorso") or alvo.Character:FindFirstChild("Torso") or alvo.Character:FindFirstChild("HumanoidRootPart")
            elseif Aimbot_ParteAlvo == "Perna" then
                parteRastrear = alvo.Character:FindFirstChild("RightLowerLeg") or alvo.Character:FindFirstChild("LeftLowerLeg") or alvo.Character:FindFirstChild("RightFoot") or alvo.Character:FindFirstChild("LeftFoot") or alvo.Character:FindFirstChild("HumanoidRootPart")
            end
            if parteRastrear then
                local offsetDinamico = CalcularOffset3D_Dinamico(camera, parteRastrear.Position)
                local alvoPos = parteRastrear.Position + Vector3.new(0, -offsetDinamico, 0)
                camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, alvoPos), Aimbot_Suavidade)
            end
        end
    end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if hum and root and hum.Health > 0 and Hitbox_Ativado then
                root.Size = Vector3.new(Hitbox_Tamanho, Hitbox_Tamanho, Hitbox_Tamanho)
                root.Transparency = Hitbox_Transparencia
                root.Material = Hitbox_Material
                root.Color = Hitbox_Cor
                root.CanCollide = false
            end
        end
    end
    local centroBaseTela = Vector2.new(viewportTamanho.X / 2, viewportTamanho.Y)
    for p, tracer in pairs(LinhasTracers) do
        if ESP_Tracers and p ~= localPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local root = p.Character.HumanoidRootPart
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local mostrar = true
                if ESP_TimesAtivado then
                    local timePlayer = GetPlayerTime(p)
                    if timePlayer then
                        mostrar = TimesMarcados[timePlayer] or false
                    else
                        mostrar = false
                    end
                end
                if mostrar then
                    local posTela, visivel = camera:WorldToViewportPoint(root.Position)
                    if visivel then tracer.From = centroBaseTela; tracer.To = Vector2.new(posTela.X, posTela.Y); tracer.Visible = true
                    else tracer.Visible = false end
                else
                    tracer.Visible = false
                end
            else tracer.Visible = false end
        else if tracer then tracer.Visible = false end end
    end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character then
            local head = p.Character:FindFirstChild("Head")
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if head and hum and ESP_Names then
                local nameGui = head:FindFirstChild("NoahzinName")
                if nameGui and nameGui:FindFirstChild("TextLabel") then
                    nameGui.TextLabel.Text = ESP_Vida and string.format("%s [%d/%d]", p.Name, math.floor(hum.Health), math.floor(hum.MaxHealth)) or p.Name
                end
            end
        end
    end
    
    -- BLOCOS PARKOUR
    if BlocosAtivado and localPlayer.Character then
        local hrp = localPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local velY = hrp.AssemblyLinearVelocity.Y
            for _, part in pairs(Hitboxes) do
                if part then
                    part.CanCollide = (velY <= 0.5 and hrp.Position.Y > (part.Position.Y + part.Size.Y / 2 - 1))
                end
            end
        end
    end
end)

