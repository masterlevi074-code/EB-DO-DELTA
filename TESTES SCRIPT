    pcall(function()
        local todosGuis = {}
        for _, gui in pairs(CoreGui:GetChildren()) do if gui:IsA("ScreenGui") then table.insert(todosGuis, gui) end end
        for _, gui in pairs(localPlayer.PlayerGui:GetChildren()) do if gui:IsA("ScreenGui") then table.insert(todosGuis, gui) end end
        for _, gui in pairs(todosGuis) do
            local nome = gui.Name:lower()
            if nome:find("auto") or nome:find("jj") then gui:Destroy()
            else for _, child in pairs(gui:GetDescendants()) do
                if (child:IsA("TextLabel") or child:IsA("TextButton")) and child.Text == "Auto jjs" then gui:Destroy(); break end
            end end
        end
    end)
    AutoJJ_Script = nil
end

local function IniciarAutoJJ()
    CarregarScriptJJ()
    if AutoJJ_Script then pcall(function() AutoJJ_Script() end) end
end

