    Placeholder = "Digite o nome...",
    Default = "",
    Callback = function(t)
        if t ~= "" then
            local encontrado = false
            local texto = t:lower()
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= localPlayer then
                    local nome = p.Name:lower()
                    local display = p.DisplayName:lower()
                    if nome:find(texto, 1, true) or display:find(texto, 1, true) then
                        if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and localPlayer.Character and localPlayer.Character:FindFirstChild("HumanoidRootPart") then
                            localPlayer.Character.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame + Vector3.new(0, 3, 0)
                            WindUI:Notify({Title = "TP", Content = "Teleportado para " .. p.Name})
                            encontrado = true
                            break
                        end
                    end
                end
            end
            if not encontrado then
                WindUI:Notify({Title = "TP", Content = "Jogador nao encontrado!"})
            end
        end
    end,
})

