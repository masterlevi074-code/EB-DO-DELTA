                if not Underground_Ativado or Underground_Voltando then return end
                local charAtual = localPlayer.Character
                if not charAtual or not charAtual:FindFirstChild("HumanoidRootPart") then return end
                local rootAtual = charAtual.HumanoidRootPart
                if rootAtual.Position.Y < -22 then
                    rootAtual.CFrame = CFrame.new(rootAtual.Position.X, -19, rootAtual.Position.Z)
                end
                if Underground_CameraPart then
                    Underground_CameraPart.CFrame = CFrame.new(rootAtual.Position.X, Underground_yCamera, rootAtual.Position.Z)
                end
            end)
            
            if Underground_ConexaoCamera then Underground_ConexaoCamera:Disconnect() end
            local camera = Workspace.CurrentCamera
            camera.CameraSubject = Underground_CameraPart
            camera.CameraType = Enum.CameraType.Follow
        else
            Underground_Voltando = true
            if Underground_Conexao then Underground_Conexao:Disconnect(); Underground_Conexao = nil end
            local camera = Workspace.CurrentCamera
            if camera then
                camera.CameraSubject = localPlayer.Character and localPlayer.Character:FindFirstChild("Humanoid")
                camera.CameraType = Enum.CameraType.Follow
            end
            if Underground_CameraPart then Underground_CameraPart:Destroy(); Underground_CameraPart = nil end
            root.CFrame = CFrame.new(root.Position.X, Underground_yCamera, root.Position.Z)
            task.wait(0.5)
            Underground_Voltando = false
        end
    end,
})

