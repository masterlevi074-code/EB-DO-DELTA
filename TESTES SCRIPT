end

local function ObterJogadorMaisProximoDaMira()
    if Aimbot_SoComItem and not TemItemEquipado() then return nil end
    local melhorAlvo = nil; local melhorPontuacao = math.huge; local camera = Workspace.CurrentCamera; local viewportTamanho = camera.ViewportSize
    local pontoMiraTela = Vector2.new(viewportTamanho.X / 2, (viewportTamanho.Y / 2) + Aimbot_OffsetTelaY); local cameraPos = camera.CFrame.Position
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character and p.Character:FindFirstChildOfClass("Humanoid") and p.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
            if JogadoresIgnorados[p.Name] then continue end; if Aimbot_TeamCheck and SaoDoMesmoTime(localPlayer, p) then continue end
            local parteBuscada = nil
            if Aimbot_ParteAlvo == "Head" then parteBuscada = p.Character:FindFirstChild("Head")
            elseif Aimbot_ParteAlvo == "Torso" then parteBuscada = p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso") or p.Character:FindFirstChild("HumanoidRootPart")
            elseif Aimbot_ParteAlvo == "Perna" then parteBuscada = p.Character:FindFirstChild("RightLowerLeg") or p.Character:FindFirstChild("LeftLowerLeg") or p.Character:FindFirstChild("RightFoot") or p.Character:FindFirstChild("LeftFoot") or p.Character:FindFirstChild("HumanoidRootPart") end
            if parteBuscada then
                if Aimbot_WallCheck and not EstaVisivel(parteBuscada) then continue end
                local offsetDinamico = CalcularOffset3D_Dinamico(camera, parteBuscada.Position)
                local posicaoAlvo3D = parteBuscada.Position + Vector3.new(0, -offsetDinamico, 0)
                local posicaoTela, visivel = camera:WorldToViewportPoint(posicaoAlvo3D)
                if visivel then
                    local distanciaReal = (parteBuscada.Position - cameraPos).Magnitude
                    local distanciaDaMira = (Vector2.new(posicaoTela.X, posicaoTela.Y) - pontoMiraTela).Magnitude
                    if not Aimbot_UsarFOV or distanciaDaMira <= Aimbot_RaioFOV then
                        local pontuacao = Aimbot_PrioridadeDistancia and (distanciaReal * 0.7 + distanciaDaMira * 0.3) or distanciaDaMira
                        if pontuacao < melhorPontuacao then melhorPontuacao = pontuacao; melhorAlvo = p end
                    end
                end
            end
        end
    end
    return melhorAlvo
end

