local function IniciarCaptura()
    BlocosCapturando = true
    BlocosPosicoes = {}
    Rayfield:Notify({Title = "Blocos", Content = "Capturando! Caminhe pelo parkour...", Duration = 3})
end

local function PararCaptura()
    BlocosCapturando = false
    if #BlocosPosicoes > 0 then
        local json = HttpService:JSONEncode(BlocosPosicoes)
        local nomeArquivo = "BlocosParkour_" .. BlocosParkourAtual .. ".txt"
        pcall(function()
            if writefile then
                writefile(nomeArquivo, json)
                Rayfield:Notify({Title = "SUCESSO!", Content = #BlocosPosicoes .. " posicoes salvas!", Duration = 5})
            end
        end)
    end
end

local function CriarBlocos()
    for _, bloco in pairs(BlocosCriados) do if bloco then bloco:Destroy() end end
    BlocosCriados = {}
    
    local nomeArquivo = "BlocosParkour_" .. BlocosParkourAtual .. ".txt"
    if not isfile or not isfile(nomeArquivo) then
        Rayfield:Notify({Title = "Erro", Content = "Parkour nao tem blocos salvos!", Duration = 3})
        return
    end
    
    local conteudo = readfile(nomeArquivo)
    local posicoes = HttpService:JSONDecode(conteudo)
    
    for _, pos in ipairs(posicoes) do
        local bloco = Instance.new("Part")
        bloco.Name = "BlocoAntiQueda"
        bloco.Size = Vector3.new(8, 1, 8)
        bloco.Position = Vector3.new(pos.x, pos.y, pos.z)
        bloco.Anchored = true
        bloco.CanCollide = true
        bloco.Color = Color3.fromRGB(0, 150, 255)
        bloco.Transparency = 0.5
        bloco.Material = Enum.Material.Neon
        bloco.Parent = Workspace
        table.insert(BlocosCriados, bloco)
    end
    
    Rayfield:Notify({Title = "Blocos", Content = #posicoes .. " blocos criados!", Duration = 3})
end

local function RemoverBlocos()
    for _, bloco in pairs(BlocosCriados) do if bloco then bloco:Destroy() end end
    BlocosCriados = {}
end

