local function GetPlayerTime(player)
    if player.Team then
        local teamName = player.Team.Name
        for time, _ in pairs(TimesMarcados) do
            if teamName:find(time:gsub("%[", ""):gsub("%]", ""), 1, true) then return time end
        end
    end
    return nil
end

local function AtualizarESP()
    if not CorESP then CorESP = Color3.fromRGB(255, 50, 50) end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character then
            local mostrarESP = true
            if ESP_TimesAtivado then local timePlayer = GetPlayerTime(p); if timePlayer then mostrarESP = TimesMarcados[timePlayer] or false else mostrarESP = false end end
            local h = p.Character:FindFirstChild("NoahzinESP")
            if h then h.Enabled = ESP_Chams and mostrarESP; pcall(function() h.FillColor = CorESP end) end
            local box = p.Character:FindFirstChild("NoahzinBox")
            if box then box.Visible = ESP_Box and mostrarESP; pcall(function() box.Color3 = CorESP end) end
            local head = p.Character:FindFirstChild("Head")
            if head then local nameGui = head:FindFirstChild("NoahzinName")
                if nameGui then nameGui.Enabled = ESP_Names and mostrarESP
                    if nameGui:FindFirstChild("TextLabel") then pcall(function() nameGui.TextLabel.TextColor3 = CorESP end) end
                end
            end
            if LinhasTracers[p] then pcall(function() LinhasTracers[p].Color = CorESP end); LinhasTracers[p].Visible = ESP_Tracers and mostrarESP end
        end
    end
end

local function CriarESP(p)
    if p == localPlayer then return end
    local function AdicionarUI(c)
        local head = c:WaitForChild("Head", 5); if not head then return end
        local h = c:FindFirstChild("NoahzinESP") or Instance.new("Highlight")
        h.Name = "NoahzinESP"; pcall(function() h.FillColor = CorESP end); h.OutlineColor = Color3.new(1,1,1); h.FillTransparency = 0.5; h.Enabled = ESP_Chams; h.Parent = c
        local bg = head:FindFirstChild("NoahzinName") or Instance.new("BillboardGui")
        bg.Name = "NoahzinName"; bg.Size = UDim2.new(0, 100, 0, 20); bg.AlwaysOnTop = true; bg.ExtentsOffset = Vector3.new(0, 3, 0); bg.Enabled = ESP_Names; bg.Parent = head
        local tl = bg:FindFirstChild("TextLabel") or Instance.new("TextLabel")
        tl.Size = UDim2.new(1, 0, 1, 0); tl.BackgroundTransparency = 1; tl.Text = p.Name; pcall(function() tl.TextColor3 = CorESP end); tl.Font = Enum.Font.GothamBold; tl.TextSize = 12; tl.TextStrokeTransparency = 0; tl.Parent = bg
        local box = c:FindFirstChild("NoahzinBox") or Instance.new("SelectionBox")
        box.Name = "NoahzinBox"; box.Adornee = c; pcall(function() box.Color3 = CorESP end); box.LineThickness = 0.05; box.SurfaceTransparency = 1; box.Visible = ESP_Box; box.Parent = c
        if not LinhasTracers[p] then local tracer = Drawing.new("Line"); tracer.Visible = false; pcall(function() tracer.Color = CorESP end); tracer.Thickness = 1.2; LinhasTracers[p] = tracer end
        task.spawn(AtualizarESP)
    end
    if p.Character then AdicionarUI(p.Character) end
    p.CharacterAdded:Connect(AdicionarUI)
end

for _, p in pairs(Players:GetPlayers()) do CriarESP(p) end
Players.PlayerAdded:Connect(CriarESP)
Players.PlayerRemoving:Connect(function(p) if LinhasTracers[p] then LinhasTracers[p]:Destroy(); LinhasTracers[p] = nil end end)

local function AplicarCorESP(novaCor)
    CorESP = novaCor or Color3.fromRGB(255, 50, 50)
    for _, plr in pairs(Players:GetPlayers()) do if plr ~= localPlayer and plr.Character then
        local h = plr.Character:FindFirstChild("NoahzinESP"); if h then pcall(function() h.FillColor = CorESP end) end
        local box = plr.Character:FindFirstChild("NoahzinBox"); if box then pcall(function() box.Color3 = CorESP end) end
        local head = plr.Character:FindFirstChild("Head")
        if head then local nameGui = head:FindFirstChild("NoahzinName"); if nameGui and nameGui:FindFirstChild("TextLabel") then pcall(function() nameGui.TextLabel.TextColor3 = CorESP end) end end
    end
    if LinhasTracers[plr] then pcall(function() LinhasTracers[plr].Color = CorESP end) end end
end

local function CalcularOffset3D_Dinamico(camera, alvoPosicao)
    local distancia = (alvoPosicao - camera.CFrame.Position).Magnitude; local fovVertical = math.rad(camera.FieldOfView)
    local alturaTelaStuds = 2 * distancia * math.tan(fovVertical / 2); return (Aimbot_OffsetPixels / camera.ViewportSize.Y) * alturaTelaStuds
end

local function EstaVisivel(alvoParte)
    local camera = Workspace.CurrentCamera; local cameraPos = camera.CFrame.Position
    local params = RaycastParams.new(); params.FilterType = Enum.RaycastFilterType.Exclude; params.FilterDescendantsInstances = {localPlayer.Character}; params.IgnoreWater = true
    local resultado = Workspace:Raycast(cameraPos, (alvoParte.Position - cameraPos), params)
    if not resultado then return true end; local alvo = alvoParte.Parent; if alvo and resultado.Instance:IsDescendantOf(alvo) then return true end; return false
end

local function SaoDoMesmoTime(jogadorA, jogadorB)
    local teamA = jogadorA.Team; local teamB = jogadorB.Team; if teamA and teamB and teamA == teamB then return true end
    if teamA and teamB and teamA.TeamColor and teamB.TeamColor then if teamA.TeamColor == teamB.TeamColor then return true end end; return false
end

local function TemItemEquipado()
