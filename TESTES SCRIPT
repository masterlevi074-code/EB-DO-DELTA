    if type(Option) == "string" then DropdownSelecionado = Option
    elseif type(Option) == "table" then local val = Option.Value or Option.CurrentOption or Option[1] or ""; if type(val) == "string" then DropdownSelecionado = val end end
end})
CombatTab:CreateButton({Name = "Adicionar", Callback = function()
   if DropdownSelecionado ~= "" and DropdownSelecionado ~= "Nenhum jogador online" then JogadoresIgnorados[DropdownSelecionado] = true; AtualizarListaIgnorados() end
end})
CombatTab:CreateButton({Name = "Remover", Callback = function()
   if DropdownSelecionado ~= "" and DropdownSelecionado ~= "Nenhum jogador online" then JogadoresIgnorados[DropdownSelecionado] = nil; AtualizarListaIgnorados() end
end})
CombatTab:CreateButton({Name = "Atualizar", Callback = function() DropdownSelecionado = ""; dropdownIgnorar:Refresh(ObterListaJogadores(), true) end})
CombatTab:CreateButton({Name = "Limpar", Callback = function() JogadoresIgnorados = {}; AtualizarListaIgnorados() end})
local ListaIgnoradosLabel = CombatTab:CreateParagraph({Title = "Ignorados", Content = "Nenhum"})
function AtualizarListaIgnorados()
   local lista = {}; for nome in pairs(JogadoresIgnorados) do table.insert(lista, " - " .. nome) end
   ListaIgnoradosLabel:Set({Title = "Ignorados (" .. #lista .. ")", Content = #lista == 0 and "Nenhum" or table.concat(lista, "\n")})
end

