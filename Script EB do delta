local function AtualizarESP()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character then
            local h = p.Character:FindFirstChild("NoahzinESP")
            if h then 
                h.Enabled = ESP_Chams 
                h.FillColor = CorESP 
            end
            local box = p.Character:FindFirstChild("NoahzinBox")
            if box then 
                box.Visible = ESP_Box 
                box.Color3 = CorESP 
            end
            local head = p.Character:FindFirstChild("Head")
            if head then
                local nameGui = head:FindFirstChild("NoahzinName")
                if nameGui then 
                    nameGui.Enabled = ESP_Names 
                    nameGui.TextLabel.TextColor3 = CorESP 
                end
            end
        end
        if LinhasTracers[p] then LinhasTracers[p].Color = CorESP end
    end
end

local function CriarESP(p)
    local function AdicionarUI(c)
        if p == localPlayer then return end
        local head = c:WaitForChild("Head", 5)
        if not head then return end

        local h = c:FindFirstChild("NoahzinESP") or Instance.new("Highlight") 
        h.Name = "NoahzinESP"; h.FillColor = CorESP; h.OutlineColor = Color3.new(1,1,1)
        h.FillTransparency = 0.5; h.Enabled = ESP_Chams; h.Parent = c

        local bg = head:FindFirstChild("NoahzinName") or Instance.new("BillboardGui") 
        bg.Name = "NoahzinName"; bg.Size = UDim2.new(0, 100, 0, 20)
        bg.AlwaysOnTop = true; bg.ExtentsOffset = Vector3.new(0, 3, 0)
        bg.Enabled = ESP_Names; bg.Parent = head

        local tl = bg:FindFirstChild("TextLabel") or Instance.new("TextLabel") 
        tl.Size = UDim2.new(1, 0, 1, 0); tl.BackgroundTransparency = 1
        tl.Text = p.Name; tl.TextColor3 = CorESP; tl.Font = Enum.Font.GothamBold
        tl.TextSize = 12; tl.TextStrokeTransparency = 0; tl.Parent = bg

        local box = c:FindFirstChild("NoahzinBox") or Instance.new("SelectionBox") 
        box.Name = "NoahzinBox"; box.Adornee = c; box.Color3 = CorESP
        box.LineThickness = 0.05; box.SurfaceTransparency = 1
        box.Visible = ESP_Box; box.Parent = c

        if not LinhasTracers[p] then
            local tracer = Drawing.new("Line")
            tracer.Visible = false; tracer.Color = CorESP; tracer.Thickness = 1.2
            LinhasTracers[p] = tracer
        end
        task.spawn(AtualizarESP)
    end
    if p.Character then AdicionarUI(p.Character) end
    p.CharacterAdded:Connect(AdicionarUI)
end

for _, p in pairs(Players:GetPlayers()) do CriarESP(p) end
Players.PlayerAdded:Connect(CriarESP)

Players.PlayerRemoving:Connect(function(p)
    if LinhasTracers[p] then LinhasTracers[p]:Destroy(); LinhasTracers[p] = nil end
end)

local function AplicarCorESP(novaCor)
    CorESP = novaCor
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= localPlayer and plr.Character then
            local h = plr.Character:FindFirstChild("NoahzinESP")
            if h then h.FillColor = novaCor end
            local box = plr.Character:FindFirstChild("NoahzinBox")
            if box then box.Color3 = novaCor end
            local head = plr.Character:FindFirstChild("Head")
            if head then
                local nameGui = head:FindFirstChild("NoahzinName")
                if nameGui and nameGui:FindFirstChild("TextLabel") then
                    nameGui.TextLabel.TextColor3 = novaCor
                end
            end
        end
        if LinhasTracers[plr] then LinhasTracers[plr].Color = novaCor end
    end
end

-- ==========================================
-- FUNÇÃO: CONVERTER PIXELS PARA OFFSET 3D BASEADO NA DISTÂNCIA
-- ==========================================
local function CalcularOffset3D_Dinamico(camera, alvoPosicao)
    -- Distância entre a câmera e o alvo
    local distancia = (alvoPosicao - camera.CFrame.Position).Magnitude
    -- Tamanho vertical da tela em studs na distância do alvo (aproximado)
    local fovVertical = math.rad(camera.FieldOfView)
    local alturaTelaStuds = 2 * distancia * math.tan(fovVertical / 2)
    -- Tamanho da tela em pixels
    local alturaTelaPixels = camera.ViewportSize.Y
    -- Converter pixels para studs
    local offsetStuds = (Aimbot_OffsetPixels / alturaTelaPixels) * alturaTelaStuds
    return offsetStuds
end

-- ==========================================
-- FUNÇÃO: OBTER JOGADOR MAIS PRÓXIMO DA MIRA
-- ==========================================
local function ObterJogadorMaisProximoDaMira()
    local alvoMaisProximo = nil
    local menorDistancia = math.huge
    local camera = Workspace.CurrentCamera
    local viewportTamanho = camera.ViewportSize
    local pontoMiraTela = Vector2.new(viewportTamanho.X / 2, (viewportTamanho.Y / 2) + Aimbot_OffsetTelaY)

    local meuTime = nil
    if Aimbot_TeamCheck and localPlayer.Character then
        meuTime = localPlayer.Character:FindFirstChild("Team")
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character and p.Character:FindFirstChildOfClass("Humanoid") and p.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
            
            if JogadoresIgnorados[p.Name] then continue end

            if Aimbot_TeamCheck and meuTime then
                local timeDoAlvo = p.Character:FindFirstChild("Team")
                if timeDoAlvo and meuTime == timeDoAlvo then continue end
            end

            local parteBuscada = Aimbot_ParteAlvo
            if parteBuscada == "Torso" then
                parteBuscada = p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso") or p.Character:FindFirstChild("HumanoidRootPart")
            else
                parteBuscada = p.Character:FindFirstChild("Head")
            end

            if parteBuscada then
                -- Calcular offset dinâmico baseado na distância
                local offsetDinamico = CalcularOffset3D_Dinamico(camera, parteBuscada.Position)
                local posicaoAlvo3D = parteBuscada.Position + Vector3.new(0, -offsetDinamico, 0)
                local posicaoTela, visivel = camera:WorldToViewportPoint(posicaoAlvo3D)
                
                if visivel then
                    local posicaoMouseObjeto = Vector2.new(posicaoTela.X, posicaoTela.Y)
                    local distanciaDaMira = (posicaoMouseObjeto - pontoMiraTela).Magnitude
                    
                    if Aimbot_UsarFOV then
                        if distanciaDaMira <= Aimbot_RaioFOV and distanciaDaMira < menorDistancia then
                            menorDistancia = distanciaDaMira
                            alvoMaisProximo = p
                        end
                    else
                        if distanciaDaMira < menorDistancia then
                            menorDistancia = distanciaDaMira
                            alvoMaisProximo = p
                        end
                    end
                end
            end
        end
    end
    return alvoMaisProximo
end

-- ==========================================
-- LOOP DE ATUALIZAÇÃO (AIMBOT + ESP)
-- ==========================================
RunService.RenderStepped:Connect(function()
    local camera = Workspace.CurrentCamera
    local viewportTamanho = camera.ViewportSize
    
    if Aimbot_UsarFOV and FOVCircle then
        FOVCircle.Position = Vector2.new(viewportTamanho.X / 2, (viewportTamanho.Y / 2) + Aimbot_OffsetTelaY)
        FOVCircle.Radius = Aimbot_RaioFOV
        FOVCircle.Thickness = Aimbot_EspessuraFOV
    end

    if Aimbot_Ativado then
        local alvo = ObterJogadorMaisProximoDaMira()
        if alvo and alvo.Character then
            local parteRastrear = Aimbot_ParteAlvo
            if parteRastrear == "Torso" then
                parteRastrear = alvo.Character:FindFirstChild("UpperTorso") or alvo.Character:FindFirstChild("Torso") or alvo.Character:FindFirstChild("HumanoidRootPart")
            else
                parteRastrear = alvo.Character:FindFirstChild("Head")
            end

            if parteRastrear then
                -- Offset DINÂMICO baseado na distância atual
                local offsetDinamico = CalcularOffset3D_Dinamico(camera, parteRastrear.Position)
                local alvoPos = parteRastrear.Position + Vector3.new(0, -offsetDinamico, 0)
                local camCFrame = camera.CFrame
                local cframeAlvoOriginal = CFrame.new(camCFrame.Position, alvoPos)
                camera.CFrame = camCFrame:Lerp(cframeAlvoOriginal, Aimbot_Suavidade)
            end
        end
    end

    -- Tracers
    local centroBaseTela = Vector2.new(viewportTamanho.X / 2, viewportTamanho.Y)
    for p, tracer in pairs(LinhasTracers) do
        if ESP_Tracers and p ~= localPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local root = p.Character.HumanoidRootPart
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local posTela, visivel = camera:WorldToViewportPoint(root.Position)
                if visivel then
                    tracer.From = centroBaseTela; tracer.To = Vector2.new(posTela.X, posTela.Y)
                    tracer.Visible = true
                else tracer.Visible = false end
            else tracer.Visible = false end
        else if tracer then tracer.Visible = false end end
    end

    -- ESP Vida
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character then
            local head = p.Character:FindFirstChild("Head")
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if head and hum then
                local nameGui = head:FindFirstChild("NoahzinName")
                if nameGui and nameGui:FindFirstChild("TextLabel") then
                    if ESP_Names then
                        if ESP_Vida then
                            nameGui.TextLabel.Text = string.format("%s [%d/%d]", p.Name, math.floor(hum.Health), math.floor(hum.MaxHealth))
                        else
                            nameGui.TextLabel.Text = p.Name
                        end
                    end
                end
            end
        end
    end
end)

