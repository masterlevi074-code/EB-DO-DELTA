-- ==========================================
-- FUNÇÃO: APLICAR COR ESP
-- ==========================================
local function AplicarCorESP(novaCor)
    CorESP = novaCor
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= localPlayer and plr.Character then
            local h = plr.Character:FindFirstChild("NoahzinESP")
            if h then h.FillColor = novaCor end
            local box = plr.Character:FindFirstChild("NoahzinBox")
            if box then box.Color3 = novaCor end
            local head = plr.Character:FindFirstChild("Head")
            if head then
                local nameGui = head:FindFirstChild("NoahzinName")
                if nameGui and nameGui:FindFirstChild("TextLabel") then
                    nameGui.TextLabel.TextColor3 = novaCor
                end
            end
        end
        if LinhasTracers[plr] then
            LinhasTracers[plr].Color = novaCor
        end
    end
end

-- ==========================================
-- FUNÇÃO: OBTER JOGADOR MAIS PRÓXIMO DA MIRA
-- ==========================================
local function ObterJogadorMaisProximoDaMira()
    local alvoMaisProximo = nil
    local menorDistancia = math.huge
    local camera = Workspace.CurrentCamera
    local viewportTamanho = camera.ViewportSize
    -- Ponto de referência na tela para o FOV (acima do centro)
    local pontoMiraTela = Vector2.new(viewportTamanho.X / 2, (viewportTamanho.Y / 2) + Aimbot_OffsetTelaY)

    local meuTime = nil
    if Aimbot_TeamCheck and localPlayer.Character then
        meuTime = localPlayer.Character:FindFirstChild("Team")
    end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character and p.Character:FindFirstChildOfClass("Humanoid") and p.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
            
            if JogadoresIgnorados[p.Name] then
                continue
            end

            if Aimbot_TeamCheck and meuTime then
                local timeDoAlvo = p.Character:FindFirstChild("Team")
                if timeDoAlvo and meuTime == timeDoAlvo then
                    continue
                end
            end

            local parteBuscada = Aimbot_ParteAlvo
            if parteBuscada == "Torso" then
                parteBuscada = p.Character:FindFirstChild("UpperTorso") or p.Character:FindFirstChild("Torso") or p.Character:FindFirstChild("HumanoidRootPart")
            else
                parteBuscada = p.Character:FindFirstChild("Head")
            end

            if parteBuscada then
                -- Detecção: usar posição com offset 3D negativo (mais baixo)
                local posicaoAlvo3D = parteBuscada.Position + Vector3.new(0, Aimbot_Offset3D_Y, 0)
                local posicaoTela, visivel = camera:WorldToViewportPoint(posicaoAlvo3D)
                
                if visivel then
                    local posicaoMouseObjeto = Vector2.new(posicaoTela.X, posicaoTela.Y)
                    local distanciaDaMira = (posicaoMouseObjeto - pontoMiraTela).Magnitude
                    
                    if Aimbot_UsarFOV then
                        if distanciaDaMira <= Aimbot_RaioFOV and distanciaDaMira < menorDistancia then
                            menorDistancia = distanciaDaMira
                            alvoMaisProximo = p
                        end
                    else
                        if distanciaDaMira < menorDistancia then
                            menorDistancia = distanciaDaMira
                            alvoMaisProximo = p
                        end
                    end
                end
            end
        end
    end
    return alvoMaisProximo
end

-- ==========================================
-- LOOP DE ATUALIZAÇÃO (AIMBOT + ESP TRACERS + ESP VIDA)
-- ==========================================
RunService.RenderStepped:Connect(function()
    local camera = Workspace.CurrentCamera
    local viewportTamanho = camera.ViewportSize
    
    -- Círculo FOV na posição da mira visual do jogo (acima do centro)
    if Aimbot_UsarFOV and FOVCircle then
        FOVCircle.Position = Vector2.new(viewportTamanho.X / 2, (viewportTamanho.Y / 2) + Aimbot_OffsetTelaY)
        FOVCircle.Radius = Aimbot_RaioFOV
        FOVCircle.Thickness = Aimbot_EspessuraFOV
    end

    -- EXECUÇÃO DO AIMBOT - Mira ABAIXO do alvo para compensar mira alta do jogo
    if Aimbot_Ativado then
        local alvo = ObterJogadorMaisProximoDaMira()
        if alvo and alvo.Character then
            local parteRastrear = Aimbot_ParteAlvo
            if parteRastrear == "Torso" then
                parteRastrear = alvo.Character:FindFirstChild("UpperTorso") or alvo.Character:FindFirstChild("Torso") or alvo.Character:FindFirstChild("HumanoidRootPart")
            else
                parteRastrear = alvo.Character:FindFirstChild("Head")
            end

            if parteRastrear then
                -- CÂMERA MIRA ABAIXO DO ALVO (offset negativo = para baixo)
                local alvoPos = parteRastrear.Position + Vector3.new(0, Aimbot_Offset3D_Y, 0)
                local camCFrame = camera.CFrame
                local cframeAlvoOriginal = CFrame.new(camCFrame.Position, alvoPos)
                camera.CFrame = camCFrame:Lerp(cframeAlvoOriginal, Aimbot_Suavidade)
            end
        end
    end

    -- ATUALIZAÇÃO DOS TRACERS
    local centroBaseTela = Vector2.new(viewportTamanho.X / 2, viewportTamanho.Y)
    for p, tracer in pairs(LinhasTracers) do
        if ESP_Tracers and p ~= localPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local root = p.Character.HumanoidRootPart
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            
            if hum and hum.Health > 0 then
                local posTela, visivel = camera:WorldToViewportPoint(root.Position)
                if visivel then
                    tracer.From = centroBaseTela
                    tracer.To = Vector2.new(posTela.X, posTela.Y)
                    tracer.Visible = true
                else
                    tracer.Visible = false
                end
            else
                tracer.Visible = false
            end
        else
            if tracer then tracer.Visible = false end
        end
    end

    -- ATUALIZAÇÃO DE VIDA NO ESP
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character then
            local head = p.Character:FindFirstChild("Head")
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if head and hum then
                local nameGui = head:FindFirstChild("NoahzinName")
                if nameGui and nameGui:FindFirstChild("TextLabel") then
                    if ESP_Names then
                        if ESP_Vida then
                            nameGui.TextLabel.Text = string.format("%s [%d/%d]", p.Name, math.floor(hum.Health), math.floor(hum.MaxHealth))
                        else
                            nameGui.TextLabel.Text = p.Name
                        end
                    end
                end
            end
        end
    end
end)

