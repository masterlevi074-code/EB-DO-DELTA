-- Parágrafo para mostrar a lista atual de jogadores ignorados
local ListaIgnoradosLabel = CombatTab:CreateParagraph({
   Title = "Jogadores Ignorados Atualmente",
   Content = "Nenhum jogador na lista"
})

-- Função para atualizar a exibição da lista de ignorados
function AtualizarListaIgnorados()
   local lista = {}
   for nome, _ in pairs(JogadoresIgnorados) do
      table.insert(lista, "• " .. nome)
   end
   
   if #lista == 0 then
      ListaIgnoradosLabel:Set({
         Title = "Jogadores Ignorados Atualmente",
         Content = "Nenhum jogador na lista"
      })
   else
      ListaIgnoradosLabel:Set({
         Title = "Jogadores Ignorados Atualmente (" .. #lista .. " jogadores)",
         Content = table.concat(lista, "\n")
      })
   end
end

-- Função para atualizar o dropdown com os jogadores online
local function AtualizarDropdownJogadores()
   local dropdown = Rayfield.Flags.DropdownIgnorar
   if not dropdown then return end
   
   local jogadores = {}
   for _, player in pairs(Players:GetPlayers()) do
      if player ~= localPlayer then
         table.insert(jogadores, player.Name)
      end
   end
   
   if #jogadores == 0 then
      jogadores = {"Nenhum jogador online"}
   end
   
   -- Atualizar o dropdown (Rayfield permite atualizar dinamicamente)
   dropdown:Refresh(jogadores, true)
end

