-- LISTA DE EXCLUSÃO
CombatTab:CreateSection("Lista de Exclusão")

local dropdownIgnorar = CombatTab:CreateDropdown({
   Name = "Jogador",
   Options = ObterListaJogadores(),
   CurrentOption = "",
   Flag = "DropdownIgnorar",
   Callback = function(Option)
      if type(Option) == "string" then
         DropdownSelecionado = Option
      elseif type(Option) == "table" then
         local val = Option.Value or Option.CurrentOption or Option[1] or ""
         if type(val) == "string" then DropdownSelecionado = val end
      end
   end,
})

CombatTab:CreateButton({
   Name = "➕ Adicionar à Lista",
   Callback = function()
      if DropdownSelecionado ~= "" and DropdownSelecionado ~= "Nenhum jogador online" then
         JogadoresIgnorados[DropdownSelecionado] = true
         AtualizarListaIgnorados()
         Rayfield:Notify({Title = "OK", Content = DropdownSelecionado .. " adicionado!", Duration = 2})
      else
         local flag = Rayfield.Flags and Rayfield.Flags["DropdownIgnorar"]
         if flag then
            local nome = flag
            if type(flag) == "table" then nome = flag.Value or flag.CurrentOption or "" end
            if type(nome) == "string" and nome ~= "" and nome ~= "Nenhum jogador online" then
               JogadoresIgnorados[nome] = true
               AtualizarListaIgnorados()
               Rayfield:Notify({Title = "OK", Content = nome .. " adicionado!", Duration = 2})
               return
            end
         end
         Rayfield:Notify({Title = "Erro", Content = "Selecione um jogador no dropdown primeiro!", Duration = 3})
      end
   end,
})

CombatTab:CreateButton({
   Name = "➖ Remover da Lista",
   Callback = function()
      if DropdownSelecionado ~= "" and DropdownSelecionado ~= "Nenhum jogador online" then
         JogadoresIgnorados[DropdownSelecionado] = nil
         AtualizarListaIgnorados()
         Rayfield:Notify({Title = "OK", Content = DropdownSelecionado .. " removido!", Duration = 2})
      else
         local flag = Rayfield.Flags and Rayfield.Flags["DropdownIgnorar"]
         if flag then
            local nome = flag
            if type(flag) == "table" then nome = flag.Value or flag.CurrentOption or "" end
            if type(nome) == "string" and nome ~= "" and nome ~= "Nenhum jogador online" then
               JogadoresIgnorados[nome] = nil
               AtualizarListaIgnorados()
               Rayfield:Notify({Title = "OK", Content = nome .. " removido!", Duration = 2})
               return
            end
         end
         Rayfield:Notify({Title = "Erro", Content = "Selecione um jogador no dropdown primeiro!", Duration = 3})
      end
   end,
})

CombatTab:CreateButton({
   Name = "🔄 Atualizar Lista",
   Callback = function()
      DropdownSelecionado = ""
      dropdownIgnorar:Refresh(ObterListaJogadores(), true)
   end,
})

CombatTab:CreateButton({
   Name = "🗑️ Limpar Tudo",
   Callback = function()
      JogadoresIgnorados = {}
      AtualizarListaIgnorados()
   end,
})

local ListaIgnoradosLabel = CombatTab:CreateParagraph({Title = "Ignorados", Content = "Nenhum"})

function AtualizarListaIgnorados()
   local lista = {}
   for nome in pairs(JogadoresIgnorados) do table.insert(lista, "• " .. nome) end
   ListaIgnoradosLabel:Set({Title = "Ignorados (" .. #lista .. ")", Content = #lista == 0 and "Nenhum" or table.concat(lista, "\n")})
end

