local function CriarBotaoDash()
   dashButtonScreen = Instance.new("ScreenGui")
   dashButtonScreen.Name = "DashButtonScreen"; dashButtonScreen.Parent = CoreGui
   local mainButton = Instance.new("TextButton")
   mainButton.Name = "DashButton"; mainButton.Size = UDim2.new(0, 60, 0, 60)
   mainButton.Position = UDim2.new(0.85, 0, 0.5, 0)
   mainButton.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
   mainButton.Text = "DASH"; mainButton.TextColor3 = Color3.fromRGB(255, 255, 255)
   mainButton.Font = Enum.Font.SourceSansBold; mainButton.TextSize = 14
   mainButton.BorderSizePixel = 0; mainButton.Active = true; mainButton.Draggable = true
   mainButton.Parent = dashButtonScreen
   Instance.new("UICorner", mainButton).CornerRadius = UDim.new(0, 12)
   local uiStroke = Instance.new("UIStroke", mainButton)
   uiStroke.Color = Color3.fromRGB(0, 120, 255); uiStroke.Thickness = 2
   mainButton.MouseButton1Click:Connect(function()
      local char = localPlayer.Character
      if char and char:FindFirstChild("HumanoidRootPart") then
         char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame * CFrame.new(0, 0, -dashStuds)
      end
   end)
end

local function RemoverBotaoDash()
   if CoreGui:FindFirstChild("DashButtonScreen") then CoreGui.DashButtonScreen:Destroy() end
   dashButtonScreen = nil
end

local function ObterListaJogadores()
    local jogadores = {}
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= localPlayer then table.insert(jogadores, player.Name) end
    end
    if #jogadores == 0 then table.insert(jogadores, "Nenhum jogador online") end
    return jogadores
end

