local function AtualizarESP()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= localPlayer and p.Character then
            local h = p.Character:FindFirstChild("NoahzinESP")
            if h then 
                h.Enabled = ESP_Chams 
                h.FillColor = CorESP 
            end

            local box = p.Character:FindFirstChild("NoahzinBox")
            if box then 
                box.Visible = ESP_Box 
                box.Color3 = CorESP 
            end
            
            local head = p.Character:FindFirstChild("Head")
            if head then
                local nameGui = head:FindFirstChild("NoahzinName")
                if nameGui then 
                    nameGui.Enabled = ESP_Names 
                    nameGui.TextLabel.TextColor3 = CorESP 
                end
            end
        end
        if LinhasTracers[p] then 
            LinhasTracers[p].Color = CorESP 
        end
    end
end

local function CriarESP(p)
    local function AdicionarUI(c)
        if p == localPlayer then return end
        
        local head = c:WaitForChild("Head", 5)
        if not head then return end

        local h = c:FindFirstChild("NoahzinESP") or Instance.new("Highlight") 
        h.Name = "NoahzinESP" 
        h.FillColor = CorESP 
        h.OutlineColor = Color3.new(1,1,1) 
        h.FillTransparency = 0.5 
        h.Enabled = ESP_Chams 
        h.Parent = c

        local bg = head:FindFirstChild("NoahzinName") or Instance.new("BillboardGui") 
        bg.Name = "NoahzinName" 
        bg.Size = UDim2.new(0, 100, 0, 20) 
        bg.AlwaysOnTop = true 
        bg.ExtentsOffset = Vector3.new(0, 3, 0) 
        bg.Enabled = ESP_Names 
        bg.Parent = head

        local tl = bg:FindFirstChild("TextLabel") or Instance.new("TextLabel") 
        tl.Size = UDim2.new(1, 0, 1, 0) 
        tl.BackgroundTransparency = 1 
        tl.Text = p.Name 
        tl.TextColor3 = CorESP 
        tl.Font = Enum.Font.GothamBold 
        tl.TextSize = 12 
        tl.TextStrokeTransparency = 0 
        tl.Parent = bg

        local box = c:FindFirstChild("NoahzinBox") or Instance.new("SelectionBox") 
        box.Name = "NoahzinBox" 
        box.Adornee = c 
        box.Color3 = CorESP 
        box.LineThickness = 0.05 
        box.SurfaceTransparency = 1 
        box.Visible = ESP_Box 
        box.Parent = c

        if not LinhasTracers[p] then
            local tracer = Drawing.new("Line")
            tracer.Visible = false
            tracer.Color = CorESP
            tracer.Thickness = 1.2
            LinhasTracers[p] = tracer
        end
     
        task.spawn(AtualizarESP)
    end
    if p.Character then AdicionarUI(p.Character) end
    p.CharacterAdded:Connect(AdicionarUI)
end

-- Inicializar ESP para jogadores existentes
for _, p in pairs(Players:GetPlayers()) do CriarESP(p) end
Players.PlayerAdded:Connect(CriarESP)

